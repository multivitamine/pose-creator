# Copy to .env (local) and set these in Vercel project settings (production).

# RunningHub
RUNNINGHUB_API_KEY=

# Supabase (server reads these via process.env; VITE_ prefix is historical)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_ACCESS_TOKEN=

# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=dw-images
VITE_R2_PUBLIC_URL=

# Background generation queue
# WEBHOOK_SECRET: any long random string; guards the RunningHub callback.
# APP_URL: the public deployed URL (e.g. https://pose-creator.vercel.app).
#   Leave empty for local dev (the reconcile poll handles completion instead).
WEBHOOK_SECRET=
APP_URL=
